# bloom-filter property tests, expressed with aql:test's spec format.
#
# Run:
#   aql test/bloom_prop_test.aql
#
# Each property is a PropertySpec (the declarative spec shape that
# `test.prop` builds): a `name`, a `gen` body that produces ONE random
# value with the iteration's seeded rand bound as `r`, and a `property`
# body that takes that value on the stack and leaves a Boolean. The
# framework runs each gen/property pair `runs` times; a single false (or
# an error) is a failure and the offending input is reported.
#
# Cheap O(k) properties (add / contains / make / params) run at the
# `test.prop` default of 100 runs via `test.run-property`. The O(m)
# properties (merge and count walk every bit) use `test.check-prop`
# with an explicit, smaller run count so the suite stays fast — the AQL
# interpreter makes a full m-bit scan expensive to repeat hundreds of
# times. Both words consume the same PropertySpec field shape.
#
# IMPORTANT — `if` is forward-only in this build. Every `if` here is
# written `if cond [then] [else]` (all arguments forward of the word);
# the mixed `cond if [...] [...]` form silently picks the wrong branch
# and the all-stack `[else] [then] cond if` form no longer dispatches.
# See dx-report.md §6.2.


"aql:test"   import end
"aql:report" import end
"./bloom.aql" import end


# --- shared generators ---------------------------------------------

# Printable charset for random keys, and a discrete set of valid false-
# positive rates. p is kept in (0, 0.5] so the derived k is always >= 1
# (k = round(log2(1/p)); p > 0.5 would round k down to 0).
def charset "abcdefghijklmnopqrstuvwxyz0123456789-_"
def plist   [0.001 0.005 0.01 0.02 0.05 0.1 0.2 0.5]


# --- reporting helper ----------------------------------------------

# Print one PropertyResult as a pass/fail line. `if` is forward-form.
def report fn [
  [res:Map] [] [
    def ok (res "ok" get)
    def nm (res "name" get)
    def msg (if ok
      [`ok   ${nm} (${(res "runs" get)} runs)`]
      [`FAIL ${nm}  failing-input: ${(res "failing-input" get)}`])
    msg print
  ]
]


# ===================================================================
# Cheap O(k) properties — default 100 runs via test.run-property.
# ===================================================================

# 1. No false negatives: a key that was just added is always contained.
def spec-add-contains (test.prop
  "add-then-contains"
  [ r.string charset (r.int 1 16) ]
  [ var [[key]
      def bf ({n: 1000, p: 0.01} Bloom.make end)
      def _ (bf key Bloom.add end)
      (bf key Bloom.contains end)
  ] ]
)
(spec-add-contains test.run-property end) report

# 2. A fresh filter (no bits set) reports every key as absent.
def spec-empty-absent (test.prop
  "empty-contains-nothing"
  [ r.string charset (r.int 1 16) ]
  [ var [[key]
      def bf ({n: 1000, p: 0.01} Bloom.make end)
      ((bf key Bloom.contains end) not)
  ] ]
)
(spec-empty-absent test.run-property end) report

# 3. make derives well-formed params for any (n, p): m >= 1, k >= 1,
#    and there are at least as many bits as hash functions (m >= k).
def spec-params-wf (test.prop
  "params-well-formed"
  [ do { n: [r.int 10 2000], p: [plist r.one-of] } ]
  [ var [[opts]
      def ps ((opts Bloom.make end) Bloom.params end)
      def m (ps "m" get)
      def k (ps "k" get)
      ((1 lte m) and ((1 lte k) and (k lte m)))
  ] ]
)
(spec-params-wf test.run-property end) report

# 4. params round-trips the constructor inputs: the reported n and p
#    are exactly what make was given.
def spec-params-roundtrip (test.prop
  "params-round-trip"
  [ do { n: [r.int 10 2000], p: [plist r.one-of] } ]
  [ var [[opts]
      def ps ((opts Bloom.make end) Bloom.params end)
      (((ps "n" get) eq (opts "n" get)) and ((ps "p" get) eq (opts "p" get)))
  ] ]
)
(spec-params-roundtrip test.run-property end) report

# 5. Bulk no false negatives: every key in a randomly-sized batch is
#    found after the whole batch is inserted.
def spec-bulk-add (test.prop
  "bulk-add-all-found"
  [ r.list-of [ r.string charset (r.int 1 12) ] (r.int 1 20) ]
  [ var [[items]
      def bf ({n: 1000, p: 0.01} Bloom.make end)
      def _ (items each [ var [[it] bf it Bloom.add end 0 ] ])
      (items each [ var [[it] (bf it Bloom.contains end) ] ] all end)
  ] ]
)
(spec-bulk-add test.run-property end) report


# ===================================================================
# O(m) properties — explicit small run counts via test.check-prop.
# These scan every bit, so 100 runs would be needlessly slow.
# Signature: name gen property runs seed max-shrinks.
# ===================================================================

# 6. Merge is membership-preserving: after merging two filters built
#    with matching (m, k), both originals' keys are still contained.
def res-merge (test.check-prop
  "merge-membership"
  [ do { x: [r.string charset (r.int 1 8)], y: [r.string charset (r.int 1 8)] } ]
  [ var [[pair]
      def a ({n: 100, p: 0.05} Bloom.make end)
      def b ({n: 100, p: 0.05} Bloom.make end)
      def _a (a (pair "x" get) Bloom.add end)
      def _b (b (pair "y" get) Bloom.add end)
      def m (a b Bloom.merge end)
      ((m (pair "x" get) Bloom.contains end) and (m (pair "y" get) Bloom.contains end))
  ] ]
  20 1 200
)
res-merge report

# 7. An empty filter estimates a cardinality of exactly zero, whatever
#    its (n, p) parameters are.
def res-empty-count (test.check-prop
  "empty-count-zero"
  [ do { n: [r.int 50 500], p: [plist r.one-of] } ]
  [ var [[opts]
      (0 eq ((opts Bloom.make end) Bloom.count end))
  ] ]
  20 1 200
)
res-empty-count report


# --- summary -------------------------------------------------------

"---" print
"fail count: " print test.fail-count end print
0 test.fail-count end assert.equal end
"all green" print
