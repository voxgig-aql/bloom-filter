# bloom-filter: minimal probabilistic set membership in AQL.
#
# Public surface (the Bloom namespace exported at the bottom):
#
#   {n:Integer, p:Decimal} Bloom.make     → BloomFilter
#   bf item                Bloom.add      → BloomFilter (mutated in place)
#   bf item                Bloom.contains → Boolean
#   bf                     Bloom.count    → Integer  (cardinality estimate)
#   bf                     Bloom.params   → Map      ({n, p, m, k})
#   a b                    Bloom.merge    → BloomFilter (m and k must match)
#
# BloomFilter is a `refine Object` subtype. Bit storage is a nested
# `Bits` Object whose fields are stringified bit indices set to 1.
#
# Imported via `"./bloom.aql" import end` from another script; that
# script doesn't need to pre-import `aql:math` because the library
# imports it itself.


"aql:math" import end


# --- types ----------------------------------------------------------

def Bits (refine Object {})

def BloomFilter (refine Object {
  n:     0
  p:     0.0
  m:     0
  k:     0
  added: 0
  bits:  (make Bits {})
})


# --- hashing --------------------------------------------------------

# 95-char printable ASCII alphabet; index 0..94 ↔ codes 32..126. AQL
# does not expose char→code directly, so we look up via the alphabet's
# `indexof`. Non-printable input maps to space (32).
def alphabet " !\"#$%&'()*+,-./0123456789:;<=>?@ABCDEFGHIJKLMNOPQRSTUVWXYZ[\\]^_`abcdefghijklmnopqrstuvwxyz{|}~"

def code-at fn [
  [i:Integer s:String] [Integer] [
    def c (s slice i (i add 1))
    def idx (c alphabet indexof)
    idx 32 add
  ]
]

def codes-of fn [
  [s:String] [List] [
    def n (s size)
    iota n each [
      s swap code-at
    ]
  ]
]

# Single FNV-1a-style step. Wrapped as a typed fn so the body avoids
# the forward-precedence trap on bare `bxor` next to a constant.
def fnv-step fn [
  [code:Integer acc:Integer] [Integer] [
    def x (acc bxor code)
    def y (x mul 16777619)
    y band 4294967295
  ]
]

def hash1 fn [
  [s:String] [Integer] [
    2166136261 (s codes-of) [fnv-step] fold
  ]
]

# h2 is OR'd with 1 so it's always odd — guarantees the index sequence
# (h1 + i*h2) mod m covers all residues.
def hash2 fn [
  [s:String] [Integer] [
    def base (1099511628211 (s codes-of) [fnv-step] fold)
    base bor 1
  ]
]


# --- bit storage ----------------------------------------------------

def bit-key fn [
  [i:Integer] [String] [
    convert String i
  ]
]

def bit-test fn [
  [i:Integer bits:Bits] [Integer] [
    def k (i bit-key)
    def v (bits k get)
    v otherwise 0
  ]
]

def bit-mark fn [
  [i:Integer bits:Bits] [] [
    def k (i bit-key)
    bits 1 k set
  ]
]


# --- index derivation -----------------------------------------------

def as-string fn [
  [item:Any] [String] [
    convert String item
  ]
]

def indices-for fn [
  [item:Any bf:BloomFilter] [List] [
    def s (item as-string)
    def h1 (s hash1)
    def h2 (s hash2)
    def m bf.m
    def k bf.k
    iota k each [
      # stack: i — forward arithmetic gives (h1 + i*h2) mod m.
      mul h2 add h1 mod m
    ]
  ]
]


# --- constructor ----------------------------------------------------

def derive-m fn [
  [p:Decimal n:Integer] [Integer] [
    def lnp (p math.log)
    def ln2 (2 math.log)
    def num (n math.negate convert Decimal mul lnp)
    def den (ln2 mul ln2)
    def raw (num div den)
    raw math.ceil
  ]
]

def derive-k fn [
  [m:Integer n:Integer] [Integer] [
    def ln2 (2 math.log)
    def raw (m convert Decimal mul ln2 div n)
    raw math.round
  ]
]

# `opts:Options` still breaks dispatch in this build (Map works);
# tracked in dx-report.md §4.1.
def make-bloom fn [
  [opts:Map] [BloomFilter] [
    def n-val (opts "n" get)
    def p-val (opts "p" get)
    def m-val (n-val p-val derive-m)
    def k-val (n-val m-val derive-k)
    make BloomFilter {
      n:     n-val
      p:     p-val
      m:     m-val
      k:     k-val
      added: 0
      bits:  (make Bits {})
    }
  ]
]


# --- core operations ------------------------------------------------

def bloom-add fn [
  [item:Any bf:BloomFilter] [BloomFilter] [
    def bits bf.bits
    def _ ((bf item indices-for) each [
      # stack: idx — push bits below, then bit-mark consumes (i, bits).
      bits swap bit-mark end
      0
    ])
    bf (bf.added 1 add) "added" set
    bf
  ]
]

def bloom-contains fn [
  [item:Any bf:BloomFilter] [Boolean] [
    def bits bf.bits
    def k bf.k
    def hits ((bf item indices-for) each [bits swap bit-test end])
    def s (0 hits [add end] fold)
    s k eq
  ]
]


# --- secondary operations -------------------------------------------

# O(m) popcount via scan.
def popcount fn [
  [bf:BloomFilter] [Integer] [
    def bits bf.bits
    def m bf.m
    def hits (iota m each [bits swap bit-test end])
    0 hits [add end] fold
  ]
]

# Swamidass–Baldi: n_est = -(m/k) * ln(1 - X/m). Branch on the
# saturated case (every bit set) up front so we don't take log(0).
#
# `if` is invoked in its full-forward form `if cond [then] [else]` —
# the mixed `cond if [then] [else]` form picks the wrong branch in
# this build (dx-report §6.2).
def bloom-count fn [
  [bf:BloomFilter] [Integer] [
    def x (bf popcount end)
    def m bf.m
    def k bf.k
    def saturated (x m eq)
    if saturated [bf.added] [
      def md (m convert Decimal)
      def kd (k convert Decimal)
      def xd (x convert Decimal)
      def ratio (md sub xd div md)
      def lnr (ratio math.log)
      def est (md math.negate div kd mul lnr)
      est math.round
    ]
  ]
]

def bloom-params fn [
  [bf:BloomFilter] [Map] [
    do {n: [bf.n], p: [bf.p], m: [bf.m], k: [bf.k]}
  ]
]


# --- merge ----------------------------------------------------------

def bloom-merge fn [
  [b:BloomFilter a:BloomFilter] [BloomFilter] [
    def am a.m
    def bm b.m
    def ak a.k
    def bk b.k
    def m-ok (am bm eq)
    def k-ok (ak bk eq)
    if (m-ok not) [
      "bloom.merge: m mismatch" error
    ] [
      if (k-ok not) [
        "bloom.merge: k mismatch" error
      ] [
        def a-bits a.bits
        def b-bits b.bits
        def _ (iota am each [
          # stack: i — if b's bit set, mark a's bit; always push 0
          # so the each body produces something.
          var [[i]
            def is-set (b-bits i bit-test end 1 eq)
            if is-set [
              a-bits i bit-mark end
              0
            ] [
              0
            ]
          ]
        ])
        a (a.added b.added add) "added" set
      ]
    ]
    a
  ]
]


# --- namespace ------------------------------------------------------
#
# Functions are exported with `/r` so the auto-evaluating map literal
# doesn't dispatch them at construction time. Types and bare values go
# in bare. See REFERENCE.md §"Word modifiers".

export "Bloom" {
  BloomFilter: BloomFilter
  Bits:        Bits
  make:        make-bloom/r
  add:         bloom-add/r
  contains:    bloom-contains/r
  count:       bloom-count/r
  params:      bloom-params/r
  merge:       bloom-merge/r
}
